# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard > Project Settings > API
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_URL="https://<project-id>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"   # NEVER expose this on the client

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://<project-id>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot via @BotFather and add it to a private group/channel
TELEGRAM_BOT_TOKEN="1234567890:ABCdef..."
# The chat ID of the group/channel (negative number for groups, e.g. -1001234567890)
# Add @userinfobot to the group to find the ID
TELEGRAM_CHAT_ID="-1001234567890"

# ── Session & Auth ────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-with-random-hex-string"

# The unlock passcode shown on the /unlock page
APP_PASSCODE="your-vault-passcode"

# Secret used to sign temporary file download URLs
FILE_URL_SIGNING_SECRET="replace-with-another-random-hex-string"
